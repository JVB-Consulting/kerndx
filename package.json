{
  "name": "salesforce-app",
  "private": true,
  "version": "1.0.0",
  "description": "KernDX — Salesforce managed-package framework",
  "scripts": {
    "lint": "eslint **/{aura,lwc}/**",
    "test": "npm run test:unit",
    "test:unit": "sfdx-lwc-jest -- --testPathPattern=force-app/",
    "test:unit:watch": "sfdx-lwc-jest --watch -- --testPathPattern=force-app/",
    "test:unit:debug": "sfdx-lwc-jest --debug -- --testPathPattern=force-app/",
    "test:unit:coverage": "sfdx-lwc-jest --coverage -- --testPathPattern=force-app/",
    "coverage:gate": "node scripts/evaluate-coverage.js",
    "scan": "npm run scan:access-modes && npm run scan:flow-references",
    "scan:access-modes": "node scripts/scan-access-modes.js",
    "scan:flow-references": "node scripts/scan-flow-references.js",
    "test:scanner": "sfdx-lwc-jest --coverage -- --testPathPattern=scanner/eslint-plugin-kerndx --collectCoverageFrom='scanner/eslint-plugin-kerndx/**/*.js'",
    "test:release": "sfdx-lwc-jest --coverage -- --testPathPattern=release-testing/__tests__ --collectCoverageFrom='release-testing/runner/**/*.js' --collectCoverageFrom='release-testing/e2e/helpers/**/*.js' --collectCoverageFrom='release-testing/scripts/**/*.js'",
    "prettier": "prettier --write \"**/*.{cls,cmp,component,css,html,js,json,md,page,trigger,xml,yaml,yml}\"",
    "prettier:verify": "prettier --list-different \"**/*.{cls,cmp,component,css,html,js,json,md,page,trigger,xml,yaml,yml}\"",
    "postinstall": "node scripts/postinstall.js",
    "precommit": "lint-staged",
    "build-package": "node scripts/build-package.js",
    "prepare-build": "node scripts/prepare-package-build.js",
    "prepare-build:dry": "node scripts/prepare-package-build.js --dry-run",
    "docs:build": "node scripts/build-docs.js",
    "docs:convert": "node scripts/convert-icapexdoc-html-to-markdown.js",
    "docs:validate": "node scripts/validate-docs.js && node scripts/validate-strategic-metrics.js && node scripts/validate-landing-metrics.js",
    "docs:fix-toc": "node scripts/validate-docs.js --fix-toc",
    "fast-start:gate": "node scripts/validate-docs.js --fast-start-gate --full",
    "fast-start:gate-wave1": "node scripts/validate-docs.js --fast-start-gate --wave 1",
    "fast-start:gate-wave2": "node scripts/validate-docs.js --fast-start-gate --wave 2",
    "fast-start:gate-doc": "node scripts/validate-docs.js --fast-start-gate --doc",
    "test:e2e": "npx playwright test --config release-testing/e2e/playwright.config.js",
    "test:e2e:headed": "npx playwright test --config release-testing/e2e/playwright.config.js --headed",
    "test:e2e:debug": "npx playwright test --config release-testing/e2e/playwright.config.js --debug",
    "test:e2e:part1": "npx playwright test --config release-testing/e2e/playwright.config.js part1-app-core",
    "test:e2e:part2": "npx playwright test --config release-testing/e2e/playwright.config.js part2-api-config",
    "test:e2e:part3": "npx playwright test --config release-testing/e2e/playwright.config.js part3-lwc-integration",
    "test:e2e:part4": "npx playwright test --config release-testing/e2e/playwright.config.js part4-scheduler-exec",
    "test:e2e:part5": "npx playwright test --config release-testing/e2e/playwright.config.js part5-streaming-setup",
    "test:e2e:part6": "npx playwright test --config release-testing/e2e/playwright.config.js part6-streaming-advanced",
    "test:e2e:part7": "npx playwright test --config release-testing/e2e/playwright.config.js part7-async-chain",
    "release:phase2": "node release-testing/runner/run-phase2.js",
    "release:phase3": "npx playwright test --config release-testing/e2e/playwright.config.js",
    "release:all": "node release-testing/runner/run-all.js",
    "test:perf:history": "node release-testing/runner/perf-history.js",
    "capture:heroes": "node release-testing/runner/capture-heroes.js",
    "test:pipeline": "cd pipeline && npm ci --omit=dev && npm test"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.4",
    "@eslint/js": "^9.39.3",
    "@lwc/eslint-plugin-lwc": "^1.1.2",
    "@playwright/test": "^1.58.2",
    "@prettier/plugin-xml": "^2.0.1",
    "@sa11y/jest": "^3.1.0",
    "@salesforce/eslint-config-lwc": "^3.2.3",
    "@salesforce/eslint-plugin-aura": "^2.0.0",
    "@salesforce/eslint-plugin-lightning": "^1.0.0",
    "@salesforce/sfdx-lwc-jest": "^7.1.2",
    "@types/eslint__js": "^8.42.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "archiver": "^7.0.1",
    "cheerio": "^1.2.0",
    "eslint": "^8.57.1",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.0.0",
    "glob": "^13.0.6",
    "globals": "^16.5.0",
    "husky": "^7.0.4",
    "lint-staged": "^12.3.7",
    "marked": "^15.0.12",
    "prettier": "^2.6.0",
    "prettier-plugin-apex": "^1.10.0",
    "turndown": "^7.2.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "lint-staged": {
    "**/*.{cls,cmp,component,css,html,js,json,md,page,trigger,xml,yaml,yml}": [
      "prettier --write"
    ],
    "**/{aura,lwc}/**": [
      "eslint"
    ]
  }
}
