        <displayFormat>AI-{0000000000}</displayFormat>
        <label>Item Number</label>
        <trackHistory>true</trackHistory>
        <type>AutoNumber</type>
    </nameField>
    <pluralLabel>API Issues</pluralLabel>
    <searchLayouts>
        <searchResultsAdditionalFields>ServiceName__c</searchResultsAdditionalFields>
        <searchResultsAdditionalFields>Status__c</searchResultsAdditionalFields>
        <searchResultsAdditionalFields>ApiCall__c</searchResultsAdditionalFields>
