<?xml version="1.0" encoding="UTF-8"?>
<CustomMetadata xmlns="http://soap.sforce.com/2006/04/metadata" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
    <label>Mask Credit Card Numbers</label>
    <protected>false</protected>
    <values>
        <field>ApplicableFieldTypes__c</field>
        <value xsi:type="xsd:string">STRING;TEXTAREA;ENCRYPTEDSTRING</value>
    </values>
    <values>
        <field>CaseSensitive__c</field>
        <value xsi:type="xsd:boolean">false</value>
    </values>
    <values>
        <field>Description__c</field>
        <value xsi:type="xsd:string">Redacts credit card numbers matching ISO/IEC 7812 issuer prefixes (Visa, MC, Amex, Discover, Diners, JCB, UnionPay) that additionally pass the Luhn mod-10 checksum. MinInputLength 15, Block DML. Review with PCI before deactivating.</value>
    </values>
    <values>
        <field>FailureAction__c</field>
        <value xsi:type="xsd:string">BlockDml</value>
    </values>
    <values>
        <field>IsActive__c</field>
        <value xsi:type="xsd:boolean">true</value>
    </values>
    <values>
        <field>MinInputLength__c</field>
        <value xsi:type="xsd:double">15.0</value>
    </values>
    <values>
        <field>Mode__c</field>
        <value xsi:type="xsd:string">CreditCard</value>
    </values>
    <values>
        <field>Order__c</field>
        <value xsi:type="xsd:double">200.0</value>
    </values>
    <values>
        <field>Pattern__c</field>
        <value xsi:type="xsd:string">\b(?:4(?:[ -]?\d){12,15}|(?:5[1-5]|2(?:2[2-9]|[3-6]\d|7[01]|720))(?:[ -]?\d){14}|3[47](?:[ -]?\d){13}|(?:6011|65\d{2}|64[4-9]\d)(?:[ -]?\d){12}|3(?:0[0-5]|[68]\d)(?:[ -]?\d){11}|(?:2131|1800|35\d{3})(?:[ -]?\d){11}|(?:62|88)(?:[ -]?\d){13,17})\b</value>
    </values>
    <values>
        <field>Replacement__c</field>
        <value xsi:type="xsd:string">[CARD_REDACTED]</value>
    </values>
</CustomMetadata>
