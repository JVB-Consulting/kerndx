<?xml version="1.0" encoding="UTF-8"?>
<CustomMetadata xmlns="http://soap.sforce.com/2006/04/metadata" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
    <label>Mask US Social Security Numbers</label>
    <protected>false</protected>
    <values>
        <field>ApplicableFieldTypes__c</field>
        <value xsi:nil="true"/>
    </values>
    <values>
        <field>CaseSensitive__c</field>
        <value xsi:type="xsd:boolean">false</value>
    </values>
    <values>
        <field>Category__c</field>
        <value xsi:type="xsd:string">Identity</value>
    </values>
    <values>
        <field>Description__c</field>
        <value xsi:type="xsd:string">Redacts US-format Social Security Numbers — nine digits, optionally separated by hyphens or spaces (separators must be consistent: 123456789 or 123-45-6789 match, 12345-6789 does not). Excludes invalid prefixes 000 and 666.</value>
    </values>
    <values>
        <field>FailureAction__c</field>
        <value xsi:type="xsd:string">LogAndContinue</value>
    </values>
    <values>
        <field>IsActive__c</field>
        <value xsi:type="xsd:boolean">false</value>
    </values>
    <values>
        <field>MinInputLength__c</field>
        <value xsi:nil="true"/>
    </values>
    <values>
        <field>Mode__c</field>
        <value xsi:type="xsd:string">Regex</value>
    </values>
    <values>
        <field>Order__c</field>
        <value xsi:type="xsd:double">110.0</value>
    </values>
    <values>
        <field>Pattern__c</field>
        <value xsi:type="xsd:string">\b(?!000|666)[0-8]\d{2}([- ]?)\d{2}\1\d{4}\b</value>
    </values>
    <values>
        <field>Replacement__c</field>
        <value xsi:type="xsd:string">XXX-XX-XXXX</value>
    </values>
    <values>
        <field>ReplacesFingerprint__c</field>
        <value xsi:nil="true"/>
    </values>
    <values>
        <field>Replaces__c</field>
        <value xsi:nil="true"/>
    </values>
    <values>
        <field>ShippedFingerprint__c</field>
        <value xsi:nil="true"/>
    </values>
</CustomMetadata>
