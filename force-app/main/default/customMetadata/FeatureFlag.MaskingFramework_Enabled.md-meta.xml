<?xml version="1.0" encoding="UTF-8"?>
<CustomMetadata xmlns="http://soap.sforce.com/2006/04/metadata" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
    <label>Masking Framework Enabled</label>
    <protected>false</protected>
    <values>
        <field>Description__c</field>
        <value xsi:type="xsd:string">Master kill switch for the data masking framework. When true, framework adapters (log engine, API framework, async chains, trigger guards) mask configured fields before persistence. Disable to bypass masking for diagnostics.</value>
    </values>
    <values>
        <field>IsActive__c</field>
        <value xsi:type="xsd:boolean">true</value>
    </values>
    <values>
        <field>IsEnabledByDefault__c</field>
        <value xsi:type="xsd:boolean">true</value>
    </values>
    <values>
        <field>ResultOnNoMatch__c</field>
        <value xsi:type="xsd:boolean">true</value>
    </values>
</CustomMetadata>
