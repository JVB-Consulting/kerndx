<?xml version="1.0" encoding="UTF-8"?>
<CustomMetadata xmlns="http://soap.sforce.com/2006/04/metadata" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
    <label>Mask US Phone Numbers</label>
    <protected>false</protected>
    <values>
        <field>ApplicableFieldTypes__c</field>
        <value xsi:nil="true"/>
    </values>
    <values>
        <field>CaseSensitive__c</field>
        <value xsi:type="xsd:boolean">false</value>
    </values>
    <values>
        <field>Category__c</field>
        <value xsi:type="xsd:string">Contact</value>
    </values>
    <values>
        <field>Description__c</field>
        <value xsi:type="xsd:string">Redacts US-format phone numbers: optional country code, parentheses around area code, hyphen/dot/space separators. Does not match international numbers — add more rules for other regions if needed.</value>
    </values>
    <values>
        <field>FailureAction__c</field>
        <value xsi:type="xsd:string">LogAndContinue</value>
    </values>
    <values>
        <field>IsActive__c</field>
        <value xsi:type="xsd:boolean">false</value>
    </values>
    <values>
        <field>MinInputLength__c</field>
        <value xsi:nil="true"/>
    </values>
    <values>
        <field>Mode__c</field>
        <value xsi:type="xsd:string">Regex</value>
    </values>
    <values>
        <field>Order__c</field>
        <value xsi:type="xsd:double">120.0</value>
    </values>
    <values>
        <field>Pattern__c</field>
        <value xsi:type="xsd:string">(?&lt;!\w)(?:\+?1[-. ]?)?\(?\d{3}\)?[-. ]?\d{3}[-. ]?\d{4}(?!\w)</value>
    </values>
    <values>
        <field>Replacement__c</field>
        <value xsi:type="xsd:string">[PHONE_REDACTED]</value>
    </values>
    <values>
        <field>ReplacesFingerprint__c</field>
        <value xsi:nil="true"/>
    </values>
    <values>
        <field>Replaces__c</field>
        <value xsi:nil="true"/>
    </values>
    <values>
        <field>ShippedFingerprint__c</field>
        <value xsi:nil="true"/>
    </values>
</CustomMetadata>
