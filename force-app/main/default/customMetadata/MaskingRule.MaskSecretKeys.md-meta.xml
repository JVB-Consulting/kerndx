<?xml version="1.0" encoding="UTF-8"?>
<CustomMetadata xmlns="http://soap.sforce.com/2006/04/metadata" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
    <label>Mask Secret Key Fields in JSON</label>
    <protected>false</protected>
    <values>
        <field>ApplicableFieldTypes__c</field>
        <value xsi:type="xsd:string">STRING;TEXTAREA</value>
    </values>
    <values>
        <field>CaseSensitive__c</field>
        <value xsi:type="xsd:boolean">false</value>
    </values>
    <values>
        <field>Category__c</field>
        <value xsi:type="xsd:string">Credentials</value>
    </values>
    <values>
        <field>Description__c</field>
        <value xsi:type="xsd:string">Redacts values under secret-carrying JSON keys (password, token, api_key, authorization, bearer, client_secret, access_token, refresh_token and variants). Walks nested objects. Scoped STRING/TEXTAREA — JSON payloads live in free-text fields only.</value>
    </values>
    <values>
        <field>FailureAction__c</field>
        <value xsi:type="xsd:string">LogAndContinue</value>
    </values>
    <values>
        <field>IsActive__c</field>
        <value xsi:type="xsd:boolean">true</value>
    </values>
    <values>
        <field>MinInputLength__c</field>
        <value xsi:nil="true"/>
    </values>
    <values>
        <field>Mode__c</field>
        <value xsi:type="xsd:string">JsonKey</value>
    </values>
    <values>
        <field>Order__c</field>
        <value xsi:type="xsd:double">320.0</value>
    </values>
    <values>
        <field>Pattern__c</field>
        <value xsi:type="xsd:string">^(password|passwd|secret|token|api[_-]?key|authorization|bearer|client[_-]?secret|private[_-]?key|access[_-]?token|refresh[_-]?token)$</value>
    </values>
    <values>
        <field>Replacement__c</field>
        <value xsi:type="xsd:string">***SECRET***</value>
    </values>
</CustomMetadata>
