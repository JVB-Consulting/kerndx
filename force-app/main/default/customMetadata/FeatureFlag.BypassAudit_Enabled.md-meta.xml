    <label>Bypass Audit Enabled</label>
    <protected>false</protected>
    <values>
        <field>Description__c</field>
        <value xsi:type="xsd:string">Kill switch for the framework-wide bypass audit. When true, bypass calls on trigger/query/DML/validation surfaces emit a LogEntry__c row with category=&apos;BypassEvent&apos;. Disable via FeatureFlagStrategy__mdt override.</value>
    </values>
    <values>
        <field>IsActive__c</field>
        <value xsi:type="xsd:boolean">true</value>
    </values>
    <values>
        <field>IsEnabledByDefault__c</field>
        <value xsi:type="xsd:boolean">true</value>
    </values>
    <values>
        <field>ResultOnNoMatch__c</field>
        <value xsi:type="xsd:boolean">true</value>
    </values>
</CustomMetadata>
