<?xml version="1.0" encoding="UTF-8"?>
<CustomMetadata xmlns="http://soap.sforce.com/2006/04/metadata" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
    <label>Mask URL Basic Auth Credentials</label>
    <protected>false</protected>
    <values>
        <field>ApplicableFieldTypes__c</field>
        <value xsi:nil="true"/>
    </values>
    <values>
        <field>CaseSensitive__c</field>
        <value xsi:type="xsd:boolean">false</value>
    </values>
    <values>
        <field>Category__c</field>
        <value xsi:type="xsd:string">Credentials</value>
    </values>
    <values>
        <field>Description__c</field>
        <value xsi:type="xsd:string">Redacts username and password embedded in URLs as https://user:password@host style. Preserves the scheme and host so log readers still see which endpoint was hit, but removes the credentials that would otherwise leak into URL fields.</value>
    </values>
    <values>
        <field>FailureAction__c</field>
        <value xsi:type="xsd:string">LogAndContinue</value>
    </values>
    <values>
        <field>IsActive__c</field>
        <value xsi:type="xsd:boolean">false</value>
    </values>
    <values>
        <field>MinInputLength__c</field>
        <value xsi:nil="true"/>
    </values>
    <values>
        <field>Mode__c</field>
        <value xsi:type="xsd:string">Regex</value>
    </values>
    <values>
        <field>Order__c</field>
        <value xsi:type="xsd:double">340.0</value>
    </values>
    <values>
        <field>Pattern__c</field>
        <value xsi:type="xsd:string">(https?://)([^:@\s]+):([^@\s]+)@</value>
    </values>
    <values>
        <field>Replacement__c</field>
        <value xsi:type="xsd:string">$1[USER]:[PWD]@</value>
    </values>
</CustomMetadata>
