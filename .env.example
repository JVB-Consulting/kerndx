# KernDX — .env example
#
# Copy this file to `.env` (which is gitignored) and fill in values as needed.
# All variables are optional; only set what you actually need.

# Required for release tests against a subscriber org
# (`npm run release:phase2`, `npm run test:release`, `npm run test:e2e`).
# Salesforce CLI alias for the subscriber scratch/sandbox org under test.
#SF_SUBSCRIBER_ORG_ALIAS=

# Required for dev-tooling scripts under scripts/
# (`npm run build:package`, `npm run setup:scratch-org`, `npm run scan:flow-refs`,
#  `npm run evaluate:coverage`, `npm run docs:build`).
# Salesforce CLI alias for your dev scratch org. Not needed for any of the
# test entry points listed in README.md → "Other test entry points".
#KERN_DEV_ORG=

# Optional. Required only if you regenerate Apex reference docs via
# `npm run docs:build`. Set to the absolute path of your IcApexDoc install.
# Install instructions: https://github.com/SCWells72/IcApexDoc/releases
#ICAPEXDOC_HOME=
